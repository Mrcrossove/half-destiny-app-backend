{
  "name": "half-destiny-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone backend for Half Destiny iOS and Android apps.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/scripts/migrate.ts up",
    "db:migrate:down": "tsx src/scripts/migrate.ts down",
    "db:status": "tsx src/scripts/migrate.ts status",
    "jobs:deletion:run": "tsx src/scripts/runDueDeletions.ts"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.11.5",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
